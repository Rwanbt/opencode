      "hook": "usePlatform",
      "provider": "PlatformProvider",
      "scope": "app",
      "source": "packages/app/src/context/platform.tsx",
      "mountFile": "packages/app/src/entry.tsx",
      "mountMarker": "PlatformProvider"
    },
