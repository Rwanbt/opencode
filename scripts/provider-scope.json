  "latent": [
    {
      "_comment": "Latent bug: WorkerPoolProvider is exported but never mounted. No runtime consumer exists in packages/app/src, but if one is added it will crash. Either mount in AppBaseProviders or remove.",
      "hook": "useWorkerPool",
      "provider": "WorkerPoolProvider",
      "scope": "unmounted",
      "source": "packages/ui/src/context/worker-pool.tsx",
