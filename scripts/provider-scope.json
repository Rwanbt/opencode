{
  "$schema": "scripts/provider-scope.schema.json",
  "_comment": "Static registry of SolidJS Context Providers in OpenCode. Each entry maps a hook to its Provider, source location, mount location, and scope (app|shell|directory|session). The check-provider-scope.ps1 script uses this registry to verify structural invariants — preventing the bug class 'consumer without an ancestor Provider'.",
  "version": 1,
  "updated": "2026-06-27",
  "scopes": {
    "app": {
      "description": "Mounted above the Router (entry.tsx or app.tsx). Every consumer anywhere in the tree can use these.",
      "mountRoots": ["packages/app/src/entry.tsx", "packages/app/src/app.tsx"]
    },
    "shell": {
      "description": "Mounted inside AppShellProviders (in app.tsx, below Router). All pages route-level see them.",
      "mountRoots": ["packages/app/src/app.tsx"]
    },
    "directory": {
      "description": "Mounted in pages/directory-layout.tsx. Only consumers below that route see them.",
      "mountRoots": ["packages/app/src/pages/directory-layout.tsx"]
    },
    "session": {
      "description": "Mounted in SessionProviders (in app.tsx, wrapped by SessionRoute). Only consumers below the /session/:id route see them.",
      "mountRoots": ["packages/app/src/app.tsx"]
    }
  },
  "providers": [
