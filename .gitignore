# Desktop sidecar binary cache (non-canonical path — canonical sidecar lives in
# packages/desktop/src-tauri/sidecars/opencode-cli-<rust-target>, populated by
# scripts/predev.ts). The 195 MB exe cached here is a build artefact, not a source.
packages/desktop/sidecars/

# gstack local reports and analytics
.gstack/

# graphify dependency graph cache (machine-generated, not for version control)
graphify-out/

# Claude Code local memory (project-specific, not for version control)
.claude/

# Dev/sprint logs (test, build, typecheck) — generated by automation, never tracked
*.log

# Agent workspace + runtime smoke logs (machine-local, never tracked)
.mavis/
.smoke/

# CI/debug investigation scratch (gh api dumps, ps1 scripts, logs) — machine-local
_bench/
