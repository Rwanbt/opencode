# Mobile runtime assets downloaded by scripts/prepare-android-runtime.sh
# (aarch64-linux-musl bun/bash/rg binaries + ld-musl + libstdc++/libgcc libs).
# These are fetched at build time, machine-architecture specific, and too big
# to commit — they must be regenerated by running prepare-android-runtime.sh.
packages/mobile/src-tauri/assets/runtime/bin/
packages/mobile/src-tauri/assets/runtime/lib/

# Non-workspace helper crates have their own Cargo.lock we don't need to
# track (they're always consumed from the workspace root lockfile).
crates/opencode-kokoro-shared/Cargo.lock

# Local LLM eval results
packages/opencode/test/tool/eval-results/

