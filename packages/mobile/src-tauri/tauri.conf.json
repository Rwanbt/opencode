{
  "$schema": "https://raw.githubusercontent.com/nicorichard/tauri-schema/main/tauri.conf.json",
  "productName": "OpenCode Mobile",
  "version": "0.1.0",
  "identifier": "ai.opencode.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://* https://* ws://* wss://*; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "15.0"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "http": {
      "scope": {
        "allow": [
          { "url": "http://**" },
          { "url": "https://**" }
        ]
      }
    },
    "deep-link": {
      "mobile": [
        { "host": "opencode.ai", "pathPrefix": ["/mobile"] }
      ],
      "desktop": {
        "schemes": ["opencode"]
      }
    },
    "notification": {
      "permissionText": "OpenCode needs notifications to alert you when tasks complete."
    }
  }
}
