<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security configuration for OpenCode Mobile.

  Goals:
  1. Trust system CAs (default Android behavior).
  2. Also trust user-installed CAs so the OpenCode self-signed TLS certificate
     (Internet mode) can be installed via Android Settings → Security →
     Install certificate and trusted by both the WebView and reqwest.
  3. Allow cleartext (HTTP) traffic everywhere so LAN mode continues to work
     without requiring users to upgrade to HTTPS.

  Why user CAs?
  OpenCode Internet mode uses a self-signed certificate generated by rcgen.
  Android 7+ no longer trusts user-installed CAs by default for apps.
  Adding <certificates src="user"/> here restores that trust, which is the
  correct approach for a developer tool connecting to a known private server.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Standard system CAs (HTTPS to production servers, Let's Encrypt, etc.) -->
            <certificates src="system"/>
            <!-- User-installed CAs: enables trusting the OpenCode self-signed cert
                 once the user installs it via Android Settings → Security →
                 Install certificate. Required for WebView SSE/WebSocket over HTTPS. -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
