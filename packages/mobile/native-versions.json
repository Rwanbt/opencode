{
  "schema_version": 1,
  "target": "aarch64-linux-android",
  "abi": "arm64-v8a",
  "onnx_runtime": {
    "version": "1.19.2",
    "source": "https://repo1.maven.org/maven2/com/microsoft/onnxruntime/onnxruntime-android/1.19.2/onnxruntime-android-1.19.2.aar",
    "sha256_source": "https://repo1.maven.org/maven2/com/microsoft/onnxruntime/onnxruntime-android/1.19.2/onnxruntime-android-1.19.2.aar.sha256"
  },
  "llama_cpp": {
    "revision": "b8683",
    "source": "https://github.com/ggml-org/llama.cpp.git",
    "build_system": "cmake",
    "configuration": "Release"
  },
  "required_native_libraries": [
    "libonnxruntime.so",
    "libllama.so",
    "libggml.so",
    "libggml-base.so",
    "libggml-cpu.so"
  ]
}