{
  "name": "@opencode-ai/mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo -b",
    "dev": "vite",
    "dev:android": "tauri android dev",
    "dev:ios": "tauri ios dev",
    "build": "vite build",
    "build:android": "tauri android build --target aarch64",
    "build:ios": "tauri ios build",
    "tauri": "tauri",
    "test": "bun test --preload ./happydom.ts ./src",
    "test:ci": "mkdir -p .artifacts/unit && bun test --preload ./happydom.ts ./src --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml"
  },
  "dependencies": {
    "@opencode-ai/app": "workspace:*",
    "@opencode-ai/ui": "workspace:*",
    "@solid-primitives/i18n": "2.2.1",
    "@solid-primitives/storage": "catalog:",
    "@tauri-apps/api": "~2.10",
    "@tauri-apps/plugin-http": "~2.5",
    "@tauri-apps/plugin-notification": "~2.3",
    "@tauri-apps/plugin-os": "~2.3",
    "@tauri-apps/plugin-process": "~2.3",
    "@tauri-apps/plugin-store": "~2.4",
    "@tauri-apps/plugin-deep-link": "~2.4",
    "@tauri-apps/plugin-haptics": "~2.3",
    "@tauri-apps/plugin-clipboard-manager": "~2.3",
    "@tauri-apps/plugin-dialog": "~2.7",
    "solid-js": "catalog:",
    "@solidjs/meta": "catalog:"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.0.11",
    "@tauri-apps/cli": "~2.10",
    "@types/bun": "catalog:",
    "typescript": "~5.6.2",
    "vite": "catalog:"
  }
}
